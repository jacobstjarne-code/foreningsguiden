---
// Deadlinebevakning — §6 UPPDRAG_POC.md. LIVE (Handoff 2026-07-10): Fable
// bytte kvittoRubrik/kvittoText till en ärlig PoC-variant som inte lovar ett
// bekräftelsemejl som aldrig skickas — se content.ts BEVAKNING-kommentaren.
// Byt till dubbel-opt-in-varianten (kommenterad i content.ts) när Resend-
// utskicket byggs.
//
// Avregistrering utan mejllänk (Codes beslut, rapporterat till Fable):
// egen sida /avregistrera/ där man skriver in sin adress, samma princip
// som anmälan. Länkad härifrån tills integritetsraden är omskriven mot det.
import { loadKommuner } from '../lib/kommuner';
import { BEVAKNING } from '../lib/content';

export interface Props {
  submitted?: boolean;
}

const { submitted = false } = Astro.props;
const kommuner = loadKommuner();
---
{submitted ? (
  <div class="email-signup fg-card">
    <h2>{BEVAKNING.kvittoRubrik}</h2>
    <p>{BEVAKNING.kvittoText}</p>
  </div>
) : (
  <form class="email-signup fg-card" method="POST" action="/api/prenumerera">
    <h2>{BEVAKNING.rubrik}</h2>
    <p>{BEVAKNING.ingress}</p>

    <label for="email-signup-email">{BEVAKNING.epostLabel}</label>
    <input type="email" id="email-signup-email" name="email" placeholder={BEVAKNING.epostPlaceholder} required autocomplete="email" />

    <fieldset>
      <legend>{BEVAKNING.kommunLabel}</legend>
      {kommuner.map((k) => (
        <label class="email-signup__kommun">
          <input type="checkbox" name="kommuner" value={k.kommun_slug} />
          {k.kommun}
        </label>
      ))}
    </fieldset>

    <label class="email-signup__consent">
      <input type="checkbox" name="samtycke" required />
      {BEVAKNING.samtycke}
    </label>

    <button type="submit" class="btn-primary">{BEVAKNING.knapp}</button>
    <p class="email-signup__integritet">
      {BEVAKNING.integritetsrad} <a href="/avregistrera/">Avregistrera dig</a>.
    </p>
  </form>
)}
