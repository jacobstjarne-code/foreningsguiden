---
// Renderas när kommunens `verifierad`-datum är äldre än STALE_THRESHOLD_DAYS
// (§4 UPPDRAG_POC.md: "renderar en synlig uppgifterna-kan-vara-inaktuella-flagga").
import { daysSinceVerified, formatDate } from '../lib/kommuner';
import { STALE } from '../lib/content';

export interface Props {
  verifierad: string;
}

const { verifierad } = Astro.props;
const text = STALE.template
  .replace('{datum}', formatDate(verifierad))
  .replace('{dagar}', String(daysSinceVerified(verifierad)));
---
<p class="stale-warning">{text}</p>
