---
// VerificationStamp — "granskad-stämpeln" (designsystem/screenshots/stamp.png).
// Bär hela förtroendemekaniken (Jacob, prioriterad före övrig tokenmigrering).
// Oxblod (--fg-verify) är RESERVERAD för just detta — sprids inte till annan UI.
import { formatStampDate } from '../lib/kommuner';

export interface Props {
  verifierad: string; // ISO-datum
}

const { verifierad } = Astro.props;
---
<span class="fg-stamp">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="20 6 9 17 4 12" />
  </svg>
  GRANSKAD · {formatStampDate(verifierad)}
</span>
