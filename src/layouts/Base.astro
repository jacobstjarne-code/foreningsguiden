---
// Bidragskollen ska indexeras från dag ett (§5 UPPDRAG_POC.md) — noindex
// default är false, till skillnad från Bandy-Brains förlaga.
export interface Props {
  title: string;
  description: string; // Fable-copy, se placeholder-konvention i respektive sida.
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
// Astro.site är ännu inte satt (domänbeslut §9.1 UPPDRAG_POC.md pågår) —
// kanonisk URL byggs riktigt i steg 3 när `site` finns i astro.config.mjs.
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
---
<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Bidragskollen</title>
    <meta name="description" content={description} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__logo">Bidragskollen</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      {'{{FABLE: förtroende-/metodtext för sidfoten, se §5 punkt 5 (Om/metod) i UPPDRAG_POC.md}}'}
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
