---
// Föreningsguiden ska indexeras från dag ett (§5 UPPDRAG_POC.md) — noindex
// default är false, till skillnad från Bandy-Brains förlaga.
//
// `title` förväntas vara den FULLSTÄNDIGA <title>-strängen (Fable avgör per
// sida om varumärkessuffixet "— Föreningsguiden" är värt teckenbudgeten —
// se content.ts). Base lägger INTE på ett eget suffix.
import { DESCRIPTOR, SIDFOT, AVSANDARE, SITE_NAMN, START } from '../lib/content';

export interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;

// Organization-schema (SOKBARHETSSPEC §4.1) — namnet är AVSANDARE (den
// namngivna redaktionella entiteten, §3.7), inte bara sajtens varumärke.
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: AVSANDARE,
  alternateName: SITE_NAMN,
  url: Astro.site?.toString(),
  description: START.metaDescription,
  knowsAbout: ['kommunala föreningsbidrag', 'föreningsstöd', 'aktivitetsstöd'],
};
---
<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Archivo:wght@600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Föreningsguiden" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="sv_SE" />
    {canonicalURL && <meta property="og:url" content={canonicalURL.toString()} />}
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__logo">
          Föreningsguiden
          <span class="site-header__descriptor">{DESCRIPTOR}</span>
        </a>
        <nav class="site-header__nav">
          <a href="/deadlines/" aria-current={Astro.url.pathname === '/deadlines/' ? 'page' : undefined}>Deadlinekalender</a>
          <a href="/om/" aria-current={Astro.url.pathname === '/om/' ? 'page' : undefined}>Om</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>{SIDFOT.kortText}</p>
      <p><a href="/om/">{SIDFOT.kallpolicyLank}</a></p>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
