---
// Avregistrering — GDPR-avregistreringsväg (§6 UPPDRAG_POC.md) utan mejllänk,
// eftersom ingen utskicksmotor är byggd. Mekanism (Codes beslut, rapporterat
// till Fable): en offentlig sida där man skriver in sin egen adress — samma
// princip som prenumerationsformuläret, ingen inloggning. POSTar till
// /api/avprenumerera, som redirectar hit med ?klar=1 för kvittot.
// prerender=false — samma skäl som deadlines/index.astro: ?klar=1 finns
// bara vid request-tid.
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { BEVAKNING } from '../../lib/content';

const klar = Astro.url.searchParams.get('klar') === '1';
---
<Base title="Avregistrera — Föreningsguiden" description="Avregistrera dig från deadlinebevakning.">
  <h1>Avregistrera dig</h1>

  {klar ? (
    <div class="email-signup fg-card">
      <h2>Avregistrerad</h2>
      <p>{BEVAKNING.avreg}</p>
    </div>
  ) : (
    <form class="email-signup fg-card" method="POST" action="/api/avprenumerera">
      <p>Skriv in adressen du bevakar med, så tar vi bort den.</p>
      <label for="avreg-email">{BEVAKNING.epostLabel}</label>
      <input type="email" id="avreg-email" name="email" placeholder={BEVAKNING.epostPlaceholder} required autocomplete="email" />
      <button type="submit" class="btn-primary">Avregistrera</button>
    </form>
  )}
</Base>
