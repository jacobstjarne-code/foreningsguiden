---
// Kommunsida — §5 punkt 2 UPPDRAG_POC.md: alla bidrag i kommunen, grupperade
// per kategori, med deadlines, krav, ansökningslänk och källhänvisning.
// Primär SEO-yta för "föreningsbidrag [kommun]". Svar-först + FAQ enligt
// SOKBARHETSSPEC §3.1/§3.3 — FAQ-schemat speglar EXAKT den synliga sektionen.
import Base from '../../../layouts/Base.astro';
import BidragCard from '../../../components/BidragCard.astro';
import StaleWarning from '../../../components/StaleWarning.astro';
import BreadcrumbList from '../../../components/BreadcrumbList.astro';
import VerificationRow from '../../../components/VerificationRow.astro';
import {
  loadKommuner, isStale, formatDate, formatRecurringDate, svenskLista,
  KATEGORI_LABELS, KATEGORIER,
} from '../../../lib/kommuner';
import type { Kategori } from '../../../lib/kommuner';
import { KOMMUN } from '../../../lib/content';

export function getStaticPaths() {
  return loadKommuner().map((kommun) => ({
    params: { slug: kommun.kommun_slug },
    props: { kommun },
  }));
}

const { kommun } = Astro.props;

const kategorierMedBidrag = KATEGORIER.filter((k: Kategori) =>
  kommun.bidrag.some((b) => b.kategori.includes(k))
);

const metaTitle = KOMMUN.metaTitleTemplate.replace(/{kommun}/g, kommun.kommun);
const metaDescription = KOMMUN.metaDescriptionTemplate.replace(/{kommun}/g, kommun.kommun);
const h1 = KOMMUN.h1Template.replace(/{kommun}/g, kommun.kommun);
const intro = KOMMUN.introTemplate.replace(/{kommun}/g, kommun.kommun);
const ansokningstext = KOMMUN.ansokningssystemTemplate
  .replace(/{kommun}/g, kommun.kommun)
  .replace(/{system}/g, kommun.ansokningssystem.namn);

// --- Svar-först-block (SOKBARHETSSPEC §3.1) — variant beroende på datat ---
const fastaDeadlines = kommun.bidrag.flatMap((b) => (b.deadlines.typ === 'fasta' ? b.deadlines.datum : []));
const kategorierText = svenskLista(kategorierMedBidrag.map((k) => KATEGORI_LABELS[k].toLowerCase()));

let svarForst = '';
if (kommun.bidrag.length === 1) {
  svarForst = KOMMUN.svarForstEtt
    .replace(/{kommun}/g, kommun.kommun)
    .replace(/{bidragsnamn}/g, kommun.bidrag[0].namn)
    .replace(/{system}/g, kommun.ansokningssystem.namn);
} else if (kommun.bidrag.length > 1 && fastaDeadlines.length === 0) {
  svarForst = KOMMUN.svarForstLopande
    .replace(/{kommun}/g, kommun.kommun)
    .replace(/{antal}/g, String(kommun.bidrag.length))
    .replace(/{kategorier}/g, kategorierText)
    .replace(/{system}/g, kommun.ansokningssystem.namn);
} else if (kommun.bidrag.length > 1) {
  const sorted = [...fastaDeadlines].sort();
  svarForst = KOMMUN.svarForstMedDeadlines
    .replace(/{kommun}/g, kommun.kommun)
    .replace(/{antal}/g, String(kommun.bidrag.length))
    .replace(/{kategorier}/g, kategorierText)
    .replace(/{tidigaste}/g, formatRecurringDate(sorted[0]))
    .replace(/{senaste}/g, formatRecurringDate(sorted[sorted.length - 1]))
    .replace(/{system}/g, kommun.ansokningssystem.namn);
}

// --- FAQ (SOKBARHETSSPEC §3.3) — synlig sektion MÅSTE spegla schemat exakt ---
const deadlinesammanfattning = kommun.bidrag
  .map((b) => (b.deadlines.typ === 'lopande'
    ? `${b.namn} söks löpande.`
    : `${b.namn} söks senast ${b.deadlines.datum.map(formatRecurringDate).join(', ')}.`))
  .join(' ');

const faqRubrik = KOMMUN.faqRubrik.replace(/{kommun}/g, kommun.kommun);
const faqEntries = kommun.bidrag.length === 0 ? [] : KOMMUN.faq.map(({ fraga, svar }) => ({
  fraga: fraga.replace(/{kommun}/g, kommun.kommun),
  svar: svar
    .replace(/{kommun}/g, kommun.kommun)
    .replace(/{antal}/g, String(kommun.bidrag.length))
    .replace(/{system}/g, kommun.ansokningssystem.namn)
    .replace(/{forvaltning}/g, kommun.forvaltning)
    .replace(/{bidragslista}/g, svenskLista(kommun.bidrag.map((b) => b.namn)))
    .replace(/{deadlinesammanfattning}/g, deadlinesammanfattning),
}));

const faqJsonLd = faqEntries.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntries.map(({ fraga, svar }) => ({
    '@type': 'Question',
    name: fraga,
    acceptedAnswer: { '@type': 'Answer', text: svar },
  })),
} : null;

// dateModified ur verifierad (SOKBARHETSSPEC §4.5) — färskhetssignal.
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: h1,
  dateModified: kommun.verifierad,
};
---
<Base title={metaTitle} description={metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(webPageJsonLd)} />
  <BreadcrumbList items={[
    { name: 'Startsida', url: '/' },
    { name: kommun.kommun, url: `/kommun/${kommun.kommun_slug}/` },
  ]} />

  <div class="kommun-header">
    <h1>{h1}</h1>
    <p class="kommun-header__meta">
      {kommun.lan} · {kommun.forvaltning} · Senast verifierad {formatDate(kommun.verifierad)}
    </p>
  </div>

  {isStale(kommun.verifierad) && <StaleWarning verifierad={kommun.verifierad} />}

  <VerificationRow kommun={kommun.kommun} verifierad={kommun.verifierad} kallaUrl={kommun.kalla_url} />

  {svarForst && <p class="svar-forst">{svarForst}</p>}

  <p>{intro}</p>

  {kommun.bidrag.length === 0 ? (
    <p>{KOMMUN.ingaBidrag}</p>
  ) : (
    kategorierMedBidrag.map((kategori) => (
      <section>
        <h2><a href={`/kommun/${kommun.kommun_slug}/${kategori}/`}>{KATEGORI_LABELS[kategori]}</a></h2>
        <ul class="bidrag-list">
          {kommun.bidrag
            .filter((b) => b.kategori.includes(kategori))
            .map((bidrag) => <BidragCard bidrag={bidrag} verifierad={kommun.verifierad} ansokningsUrl={kommun.ansokningssystem.url} />)}
        </ul>
      </section>
    ))
  )}

  <section>
    <h2>{KOMMUN.ansokningssystemRubrik}</h2>
    <p>
      {ansokningstext}{' '}
      <a href={kommun.ansokningssystem.url}>{kommun.ansokningssystem.url}</a>
    </p>
  </section>

  {faqEntries.length > 0 && (
    <section>
      <h2>{faqRubrik}</h2>
      <dl class="faq-list">
        {faqEntries.map(({ fraga, svar }) => (
          <>
            <dt>{fraga}</dt>
            <dd>{svar}</dd>
          </>
        ))}
      </dl>
    </section>
  )}
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
</Base>
