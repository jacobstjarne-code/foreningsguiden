---
// Startsida — §5 punkt 1 UPPDRAG_POC.md: värdeproposition, kommunväljare,
// deadlineöversikt. Kommunväljaren och deadlineöversikten är datadrivna
// (Code); all löptext kommer från content.ts (Fable).
import Base from '../layouts/Base.astro';
import UrgencyChip from '../components/UrgencyChip.astro';
import KommunValjare from '../components/KommunValjare.astro';
import { loadKommuner, getDeadlineEntries, formatDate, daysUntil, getUrgency, todayISO, KATEGORI_LABELS } from '../lib/kommuner';
import { START } from '../lib/content';

const kommuner = loadKommuner();
const today = todayISO();
const kommandeDeadlines = getDeadlineEntries(today).filter((e) => !e.isLopande).slice(0, 5);
---
<Base title={START.metaTitle} description={START.metaDescription}>
  <h1>{START.h1}</h1>
  <p>{START.hero}</p>

  <section>
    <h2>{START.kommunvaljareRubrik}</h2>
    <KommunValjare kommuner={kommuner} />
  </section>

  <section>
    <h2>Närmast i tid</h2>
    <p>{START.kalenderPuff}</p>
    <table class="deadline-table">
      <thead>
        <tr><th>Läge</th><th>Datum</th><th>Bidrag</th><th>Kommun</th><th>Kategori</th></tr>
      </thead>
      <tbody>
        {kommandeDeadlines.map((e) => (
          <tr>
            <td><UrgencyChip urgency={getUrgency(daysUntil(e.dateISO!, today))} /></td>
            <td>{formatDate(e.dateISO!)}</td>
            <td><a href={`/kommun/${e.kommunSlug}/`}>{e.bidragNamn}</a></td>
            <td>{e.kommun}</td>
            <td>{e.kategori.map((k) => KATEGORI_LABELS[k]).join(', ')}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p><a href="/deadlines/">Se hela deadlinekalendern →</a></p>
  </section>
</Base>
